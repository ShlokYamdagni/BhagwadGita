# --- AI / LLM Configuration ---
# Your Gemini API Key from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: OpenAI API Key if you want to switch providers
OPENAI_API_KEY=

# --- Database Configurations ---
# PostgreSQL production/local database URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gita_db
# Local fallback SQLite database path (used automatically if DATABASE_URL connection fails)
SQLITE_DB_PATH=backend/gita.db

# --- Security & JWT Configurations ---
# Generate a secure secret using: openssl rand -hex 32
JWT_SECRET=8f45a0b12f6cdbc229ab1de278918cb4691456d8f89b5314e1a0650961b72e9a
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Server Ports ---
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- Frontend (Client) Configurations ---
NEXT_PUBLIC_API_URL=http://localhost:8000
